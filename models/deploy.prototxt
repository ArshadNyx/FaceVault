    use_global_stats: true
  }
}
layer {
  name: "layer_1_2_scale1"
  type: "Scale"
  bottom: "layer_1_2_conv1"
  top: "layer_1_2_conv1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "layer_1_2_relu1"
  type: "ReLU"
  bottom: "layer_1_2_conv1"
  top: "layer_1_2_conv1"
}
layer {
  name: "layer_1_2_conv2"
  type: "Convolution"
  bottom: "layer_1_2_conv1"
  top: "layer_1_2_conv2"
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "layer_1_2_bn2"
  type: "BatchNorm"
  bottom: "layer_1_2_conv2"
  top: "layer_1_2_conv2"
  batch_norm_param {
    use_global_stats: true
