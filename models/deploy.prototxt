name: "ResNet-10"
layer {
  name: "data"
  type: "Input"
  top: "data"
  input_param {
    shape {
      dim: 1
      dim: 3
      dim: 300
      dim: 300
    }
  }
}
layer {
  name: "conv1"
  type: "Convolution"
  bottom: "data"
  top: "conv1"
  convolution_param {
    num_output: 16
    bias_term: false
    pad: 3
    kernel_size: 7
    stride: 2
  }
}
layer {
  name: "conv1_bn"
  type: "BatchNorm"
  bottom: "conv1"
  top: "conv1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "conv1_scale"
  type: "Scale"
  bottom: "conv1"
  top: "conv1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "conv1_relu"
  type: "ReLU"
  bottom: "conv1"
  top: "conv1"
}
layer {
  name: "pool1"
  type: "Pooling"
  bottom: "conv1"
  top: "pool1"
  pooling_param {
    pool: MAX
    kernel_size: 3
    stride: 2
  }
}
layer {
  name: "layer_1_1_conv1"
  type: "Convolution"
  bottom: "pool1"
  top: "layer_1_1_conv1"
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "layer_1_1_bn1"
  type: "BatchNorm"
  bottom: "layer_1_1_conv1"
  top: "layer_1_1_conv1"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "layer_1_1_scale1"
  type: "Scale"
  bottom: "layer_1_1_conv1"
  top: "layer_1_1_conv1"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "layer_1_1_relu1"
  type: "ReLU"
  bottom: "layer_1_1_conv1"
  top: "layer_1_1_conv1"
}
layer {
  name: "layer_1_1_conv2"
  type: "Convolution"
  bottom: "layer_1_1_conv1"
  top: "layer_1_1_conv2"
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "layer_1_1_bn2"
  type: "BatchNorm"
  bottom: "layer_1_1_conv2"
  top: "layer_1_1_conv2"
  batch_norm_param {
    use_global_stats: true
  }
}
layer {
  name: "layer_1_1_scale2"
  type: "Scale"
  bottom: "layer_1_1_conv2"
  top: "layer_1_1_conv2"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "layer_1_1_sum"
  type: "Eltwise"
  bottom: "pool1"
  bottom: "layer_1_1_conv2"
  top: "layer_1_1_sum"
  eltwise_param {
    operation: SUM
  }
}
layer {
  name: "layer_1_1_relu2"
  type: "ReLU"
  bottom: "layer_1_1_sum"
  top: "layer_1_1_sum"
}
layer {
  name: "layer_1_2_conv1"
  type: "Convolution"
  bottom: "layer_1_1_sum"
  top: "layer_1_2_conv1"
  convolution_param {
    num_output: 32
    bias_term: false
    pad: 1
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "layer_1_2_bn1"
  type: "BatchNorm"
  bottom: "layer_1_2_conv1"
  top: "layer_1_2_conv1"
