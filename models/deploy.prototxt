}
layer {
  name: "layer_1_2_scale2"
  type: "Scale"
  bottom: "layer_1_2_conv2"
  top: "layer_1_2_conv2"
  scale_param {
    bias_term: true
  }
}
layer {
  name: "layer_1_2_sum"
  type: "Eltwise"
  bottom: "layer_1_1_sum"
  bottom: "layer_1_2_conv2"
  top: "layer_1_2_sum"
  eltwise_param {
    operation: SUM
  }
}
layer {
  name: "layer_1_2_relu2"
  type: "ReLU"
  bottom: "layer_1_2_sum"
  top: "layer_1_2_sum"
}
layer {
  name: "layer_2_1_conv1"
