  }
}
layer {
  name: "conv5_relu"
  type: "ReLU"
  bottom: "conv5"
  top: "conv5"
}
layer {
  name: "mbox_loc"
  type: "Convolution"
  bottom: "conv5"
  top: "mbox_loc"
  convolution_param {
    num_output: 8
    bias_term: true
    pad: 0
    kernel_size: 3
    stride: 1
  }
}
layer {
  name: "mbox_loc_perm"
  type: "Permute"
  bottom: "mbox_loc"
  top: "mbox_loc_perm"
  permute_param {
    order: 0
    order: 2
    order: 3
    order: 1
  }
}
layer {
  name: "mbox_loc_flat"
  type: "Flatten"
  bottom: "mbox_loc_perm"
  top: "mbox_loc_flat"
