  flatten_param {
    axis: 1
  }
}
layer {
  name: "mbox_priorbox"
  type: "PriorBox"
  bottom: "conv5"
  bottom: "data"
  top: "mbox_priorbox"
  prior_box_param {
    min_size: 16.0
    max_size: 32.0
